"chassis_control\system_stm32f4xx.o"
--library_type=microlib --strict --scatter "chassis_control\chassis_control.sct"
--summary_stderr --info summarysizes --map --xref --callgraph --symbols
--info sizes --info totals --info unused --info veneers
--list "chassis_control.map" -o chassis_control\chassis_control.axf